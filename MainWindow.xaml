<Window x:Class="demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:demo"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <!-- 
            HOME GRID
            This grid serves as the main landing page  of the application.
            It contains a logo for AI , a welcome message to greet users,
            and a navigation button to proceed to the next section.
            Currently hidden by default.
        -->
        <Grid x:Name="home_grid" Visibility="Visible" Background="Black">
            
            <!-- Logo -->
            <Image 
                Source="/logo.png" 
                
                Width="300"
                Margin="250,100,250,217"
                   />
<!-- welcome message-->
            <TextBlock
                Text="WELCOME TO SYFER"
                Height="35"
                Width="270"
                TextAlignment="Center"
                Margin="265,230,265,162"
                FontFamily="Times New Roman"
                FontSize="20"
                FontWeight="ExtraBold"
                Foreground="AntiqueWhite"
                />
            <TextBox
                Text="Your Cyber Bestie"
                Height="30"
                Width="300"
                Margin="0,130,0,0"
                Background="Black"
                Foreground="AntiqueWhite"
                FontFamily="Times New Roman"
                FontSize="17"
                TextAlignment="Center"
                BorderBrush="Black"
                />

            <!-- button to continue-->
            <Button 
                Height="40"
                Width="300"
                Margin="0,230,0,0"
                Content="Get Starded"
                Click="proceed"
                Background="DeepPink"
                FontSize="14"
                FontWeight="Bold"
                Foreground="AntiqueWhite"
                BorderBrush="AntiqueWhite"
                />

        </Grid>

        <!-- 
            USERNAME GRID
            This grid is for prompting the user for username.
            It contains a logo for AI, a textbox for users to enter their name,
            and a submit button to save the username.
            Hidden .
        -->
        <Grid x:Name="username_grid" Visibility="Hidden" Background="Black">


            <!-- Logo -->
            <Image 
                Source="/logo.png" 
                Height="200"
                Width="300"
                Margin="0,0,0,200"
                   />
            <!-- Hint message-->
            <TextBlock
                Text="Enter username"
                Height="20"
                Width="270"
                TextAlignment="Justify"
                Margin="0,30,0,0"
                FontFamily="Arial Rounded MT Bold"
                />
            
            <!-- Enter/Prompt username-->
            <TextBox
                Height="40"
                Width="270"
                TextAlignment="Center"
                Margin="0,100,0,0"
                FontFamily="Arial Rounded MT Bold"
                x:Name="usernames_input"
                />

            <!-- error message-->
            <TextBlock
                x:Name="username_error"
         Text="please enter username to continue..."
         Height="20"
         Width="270"
         TextAlignment="Justify"
         Margin="0,180,0,0"
         Foreground="HotPink"
         FontFamily="Arial Rounded MT Bold"
         />

            <!-- button to submit name-->
            <Button 
        Height="40"
        Width="270"
        Margin="0,250,0,0"
        Content="submit username"
        Click="submit_name"
        />

        </Grid>

        <!-- 
            CHAT GRID
            This grid handles all messaging and conversation-related features of the application.
            It contains a ListView to display chat messages, a textbox for typing questions,
            and a submit button to send the question to the chat.
            Starting in a hidden state.
        -->
        <Grid x:Name="chat_grid" Visibility="Hidden">


            <!-- List view to show messages show messages-->
            <ListView  
                x:Name="chats" 
                Height="320"
                Margin="0,0,0,80"
                Background="LightPink"
                BorderBrush="DeepPink"
                BorderThickness="3"
                />
            
            
            <!-- TextBox to prompt questions-->
            <TextBox
                x:Name="question"
                Height="50"
                Width="480"
                Margin="0,300,300,0"
                BorderBrush="DeepPink"
                Background="HotPink"
                />

            <!-- button to submit -->
            <Button
                Height="50"
                Width="280"
                Margin="490,300,0,0"
                Content="send "
                Click="send"
                Background="DeepPink"
                />

            <Button
                x:Name="btnViewTasks"
                  Content="View Tasks"
                  Width="100"
                  Height="40"
                  Background="HotPink"
                  BorderBrush="DeepPink"
                  Margin="670,0,0,350"
                  Click="view_allTask"/>

            <Button x:Name="quiz_button"
                  Content="Cyber Quiz"
                  Width="100"
                  Height="40"
                  Margin="460,0,0,350"
                  Background="HotPink"
                  BorderBrush="DeepPink"
                  Click="open_quiz"/>

        </Grid>

			<!--<Grid
			x:Name="task_grid"
			Visibility ="Hidden"
			>-->
				<!--start of task grid-->
				<!--Listview-->
       <!-- <ListView
					Height="300"
					Width="700"
					Margin ="0,0,0,110"
					x:Name="chatss"
				/>-->
        <!--Textbox-->
           <!-- <TextBox 
					Height="50"
					Width="250"
					Margin="0,300,350,0"
					x:Name ="questions"
					/>-->

            <!--button to submit question-->
				<!--<Button 
					Height="40"
					Width="250"
					Margin="200,300,0,0"
					Content="submit_task"
					
					Click="submit_task"
					/>-->
                
                <!--Button to view tasks-->
           <!-- <Button 
                Height="50"
                Width="100"
                Content="view task"
                Margin="570,300,0,0"
                Click="view_allTask"
                />-->


       <!-- </Grid>end of task grid-->
        
        <!--Grid page to view all the tasks-->
        <Grid 
            x:Name="viewTask_grid"
            Visibility="Hidden"
            ><!--start of grid-->
            
            <!--listview Grid to manage all the tasks-->
            <ListView 
                x:Name="view_tasks"
                Height="350"
                Width="750"
                Margin="0,0,0,70"
                
                MouseDoubleClick="manage_task" 
                
                
                
                />

            <!--add back to chats button-->
            <Button
                Height="50"
                Width="200"
                Content="back to chats"
                Margin="0,350,0,0"
                Click="back_to_chats"
                />



        </Grid><!--end of grid-->

        <Grid x:Name="quiz_grid" Visibility="Hidden" Background="LightPink">

            <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="500">

                <TextBlock Text="Cybersecurity Quiz"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

                <TextBlock x:Name="questionText"
                   FontSize="18"
                   TextWrapping="Wrap"
                   Margin="0,0,0,20"/>

                <TextBox x:Name="answerBox"
                 Height="35"
                 Margin="0,0,0,20"/>

                <Button Content="Submit Answer"
                        Background="HotPink"
                Click="submitAnswer"/>

                <Button Content="Back to Chat"
                        Background="HotPink"
                Margin="0,10,0,0"
                Click="backToChat"/>

            </StackPanel>

        </Grid>




    </Grid><!--end of parent grid-->
    
    
    
    
</Window>